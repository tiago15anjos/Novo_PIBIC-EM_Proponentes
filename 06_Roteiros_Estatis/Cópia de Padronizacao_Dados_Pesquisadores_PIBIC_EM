ion(scope) {\n","function span(text, styleAttributes = {}) {\n","  const element = document.createElement('span');\n","  element.textContent = text;\n","  for (const key of Object.keys(styleAttributes)) {\n","    element.style[key] = styleAttributes[key];\n","  }\n","  return element;\n","}\n","\n","// Max number of bytes which will be uploaded at a time.\n","const MAX_PAYLOAD_SIZE = 100 * 1024;\n","\n","function _uploadFiles(inputId, outputId) {\n","  const steps = uploadFilesStep(inputId, outputId);\n","  const outputElement = document.getElementById(outputId);\n","  // Cache steps on the outputElement to make it available for the next call\n","  // to uploadFilesContinue from Python.\n","  outputElement.steps = steps;\n","\n","  return _uploadFilesContinue(outputId);\n","}\n","\n","// This is roughly an async generator (not supported in the browser yet),\n","// where there are multiple asynchronous steps and the Python side is going\n","// to poll for completion of each step.\n","// This uses a Promise to block the python side on completion of each step,\n","// then passes the result of the previous step as the input to the next step.\n","function _uploadFilesContinue(outputId) {\n","  const outputElement = document.getElementById(outputId);\n","  const steps = outputElement.steps;\n","\n","  const next = steps.next(outputElement.lastPromiseValue);\n","  return Promise.resolve(next.value.promise).then((value) => {\n","    // Cache the last promise value to make it available to the next\n","    // step of the generator.\n","    outputElement.lastPromiseValue = value;\n","    return next.value.response;\n","  });\n","}\n","\n","/**\n"," * Generator function which is called between each async step of the upload\n"," * process.\n"," * @param {string} inputId Element ID of the input file picker element.\n"," * @param {string} outputId Element ID of the output display.\n"," * @return {!Iterable<!Object>} Iterable of next steps.\n"," */\n","function* uploadFilesStep(inputId, outputId) {\n","  const inputElement = document.getElementById(inputId);\n","  inputElement.disabled = false;\n","\n","  const outputElement = document.getElementById(outputId);\n","  outputElement.innerHTML = '';\n","\n","  const pickedPromise = new Promise((resolve) => {\n","    inputElement.addEventListener('change', (e) => {\n","      resolve(e.target.files);\n","    });\n","  });\n","\n","  const cancel = document.createElement('button');\n","  inputElement.parentElement.appendChild(cancel);\n","  cancel.textContent = 'Cancel upload';\n","  const cancelPromise = new Promise((resolve) => {\n","    cancel.onclick = () => {\n","      resolve(null);\n","    };\n","  });\n","\n","  // Wait for the user to pick the files.\n","  const files = yield {\n","    promise: Promise.race([pickedPromise, cancelPromise]),\n","    response: {\n","      action: 'starting',\n","    }\n","  };\n","\n","  cancel.remove();\n","\n","  // Disable the input element since further picks are not allowed.\n","  inputElement.disabled = true;\n","\n","  if (!files) {\n","    return {\n","      response: {\n","        action: 'complete',\n","      }\n","    };\n","  }\n","\n","  for (const file of files) {\n","    const li = document.createElement('li');\n","    li.append(span(file.name, {fontWeight: 'bold'}));\n","    li.append(span(\n","        `(${file.type || 'n/a'}) - ${file.size} bytes, ` +\n","        `last modified: ${\n","            file.lastModifiedDate ? file.lastModifiedDate.toLocaleDateString() :\n","                                    'n/a'} - `));\n","    const percent = span('0% done');\n","    li.appendChild(percent);\n","\n","    outputElement.appendChild(li);\n","\n","    const fileDataPromise = new Promise((resolve) => {\n","      const reader = new FileReader();\n","      reader.onload = (e) => {\n","        resolve(e.target.result);\n","      };\n","      reader.readAsArrayBuffer(file);\n","    });\n","    // Wait for the data to be ready.\n","    let fileData = yield {\n","      promise: fileDataPromise,\n","      response: {\n","        action: 'continue',\n","      }\n","    };\n","\n","    // Use a chunked sending to avoid message size limits. See b/62115660.\n","    let position = 0;\n","    do {\n","      const length = Math.min(fileData.byteLength - position, MAX_PAYLOAD_SIZE);\n","      const chunk = new Uint8Array(fileData, position, length);\n","      position += length;\n","\n","      const base64 = btoa(String.fromCharCode.apply(null, chunk));\n","      yield {\n","        response: {\n","          action: 'append',\n","          file: file.name,\n","          data: base64,\n","        },\n","      };\n","\n","      let percentDone = fileData.byteLength === 0 ?\n","          100 :\n","          Math.round((position / fileData.byteLength) * 100);\n","      percent.textContent = `${percentDone}% done`;\n","\n","    } while (position < fileData.byteLength);\n","  }\n","\n","  // All done.\n","  yield {\n","    response: {\n","      action: 'complete',\n","    }\n","  };\n","}\n","\n","scope.google = scope.google || {};\n","scope.google.colab = scope.google.colab || {};\n","scope.google.colab._files = {\n","  _uploadFiles,\n","  _uploadFilesContinue,\n","};\n","})(self);\n","</script> "]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Saving PIBIC_EM_BASE_COM_METRICAS_AREAS.xlsx to PIBIC_EM_BASE_COM_METRICAS_AREAS.xlsx\n","Arquivo recebido: PIBIC_EM_BASE_COM_METRICAS_AREAS.xlsx\n"]}],"source":["# ── 1) SETUP E UPLOAD ──────────────────────────────────────────────────────────\n","!pip -q install openpyxl\n","\n","from google.colab import files\n","import pandas as pd\n","import numpy as np\n","import unicodedata\n","\n","print(\"Envie o arquivo original (.xlsx) quando solicitado.\")\n","uploaded = files.upload()  # Selecione: PIBIC_EM_BASE_COM_METRICAS_AREAS.xlsx\n","\n","# Defina o nome exato do arquivo enviado:\n","INPUT_FILENAME = [k for k in uploaded.keys()][0]\n","print(\"Arquivo recebido:\", INPUT_FILENAME)\n"]},{"cell_type":"code","source":["# ── 2) PROCESSAMENTO ───────────────────────────────────────────────────────────\n","\n","# -------- Helpers --------\n","def normalize_ascii_lower(s):\n","    if pd.isna(s):\n","        return \"\"\n","    s = str(s).strip().lower()\n","    s = unicodedata.normalize(\"NFKD\", s).encode(\"ascii\", \"ignore\").decode(\"utf-8\")\n","    return s\n","\n","def corrige_uf(x):\n","    if pd.isna(x):\n","        return None\n","    x = str(x).strip().upper()\n","    mapa_extenso = {\n","        \"SAO PAULO\": \"SP\", \"SÃO PAULO\": \"SP\",\n","        \"MARANHAO\": \"MA\", \"MARANHÃO\": \"MA\",\n","        \"CEARA\": \"CE\", \"CEARÁ\": \"CE\",\n","        \"PARA\": \"PA\", \"PARÁ\": \"PA\",\n","        \"PARANA\": \"PR\", \"PARANÁ\": \"PR\",\n","        \"RIO DE JANEIRO\": \"RJ\", \"RORAIMA\": \"RR\", \"RONDONIA\": \"RO\", \"RONDÔNIA\": \"RO\",\n","        \"AMAZONAS\":\"AM\",\"AMAPA\":\"AP\",\"AMAPÁ\":\"AP\",\"ACRE\":\"AC\",\"TOCANTINS\":\"TO\",\n","        \"ALAGOAS\":\"AL\",\"BAHIA\":\"BA\",\"DISTRITO FEDERAL\":\"DF\",\n","        \"ESPIRITO SANTO\":\"ES\",\"ESPÍRITO SANTO\":\"ES\",\"GOIAS\":\"GO\",\"GOIÁS\":\"GO\",\n","        \"MINAS GERAIS\":\"MG\",\"MATO GROSSO\":\"MT\",\"MATO GROSSO DO SUL\":\"MS\",\n","        \"PARAIBA\":\"PB\",\"PARAÍBA\":\"PB\",\"PERNAMBUCO\":\"PE\",\"PIAUI\":\"PI\",\"PIAUÍ\":\"PI\",\n","        \"RIO GRANDE DO NORTE\":\"RN\",\"RIO GRANDE DO SUL\":\"RS\",\n","        \"SANTA CATARINA\":\"SC\",\"SERGIPE\":\"SE\"\n","    }\n","    if x in mapa_extenso:\n","        return mapa_extenso[x]\n","    if len(x) == 2:\n","        return x\n","    return None\n","\n","mapa_regiao = {\n","    \"AC\": \"Norte\", \"AP\": \"Norte\", \"AM\": \"Norte\", \"PA\": \"Norte\", \"RO\": \"Norte\", \"RR\": \"Norte\", \"TO\": \"Norte\",\n","    \"AL\": \"Nordeste\", \"BA\": \"Nordeste\", \"CE\": \"Nordeste\", \"MA\": \"Nordeste\", \"PB\": \"Nordeste\", \"PE\": \"Nordeste\",\n","    \"PI\": \"Nordeste\", \"RN\": \"Nordeste\", \"SE\": \"Nordeste\",\n","    \"DF\": \"Centro-Oeste\", \"GO\": \"Centro-Oeste\", \"MT\": \"Centro-Oeste\", \"MS\": \"Centro-Oeste\",\n","    \"ES\": \"Sudeste\", \"MG\": \"Sudeste\", \"RJ\": \"Sudeste\", \"SP\": \"Sudeste\",\n","    \"PR\": \"Sul\", \"RS\": \"Sul\", \"SC\": \"Sul\"\n","}\n","\n","def tipo_ies_row(class_instituicao, categoria_administrativa):\n","    ci = \"\" if pd.isna(class_instituicao) else str(class_instituicao).upper()\n","    ca = \"\" if pd.isna(categoria_administrativa) else str(categoria_administrativa).upper()\n","\n","    # Regra: IF e CEFT entram em publica_federal\n","    if \"INSTITUTO FEDERAL\" in ci or \"CEFT\" in ci:\n","        return \"publica_federal\"\n","    if \"UNIAO\" in ca or \"UNIÃO\" in ca or \"FEDERAL\" in ca:\n","        return \"publica_federal\"\n","    if \"ESTADUAL\" in ca:\n","        return \"publica_estadual\"\n","    if \"MUNICIPAL\" in ca:\n","        return \"publica_municipal\"\n","    if \"PRIVADA\" in ca and \"SEM\" in ca:\n","        return \"privada_sem_fins\"\n","    if \"PRIVADA\" in ca and \"COM\" in ca:\n","        return \"privada_com_fins\"\n","    return \"outras\"\n","\n","def igc_categoria_val(x):\n","    if pd.isna(x):\n","        return \"Sem IGC\"\n","    try:\n","        fx = int(x)\n","    except:\n","        return \"Sem IGC\"\n","    if fx in (4,5):\n","        return \"IGC Alto\"\n","    if fx == 3:\n","        return \"IGC Médio\"\n","    if fx in (1,2):\n","        return \"IGC Baixo\"\n","    return \"Sem IGC\"\n","\n","def nivel_producao_val(h):\n","    if pd.isna(h):\n","        return \"Sem dados\"\n","    try:\n","        h = float(h)\n","    except:\n","        return \"Sem dados\"\n","    if h <= 1: return \"Muito Baixa\"\n","    if h <= 4: return \"Baixa\"\n","    if h <= 10: return \"Média\"\n","    if h <= 20: return \"Alta\"\n","    return \"Muito Alta\"\n","\n","def area_macro_from_area(area_str):\n","    if not isinstance(area_str, str):\n","        return \"Não classificado\"\n","    x = area_str.lower()\n","    if any(k in x for k in [\"physics\",\"mathematics\",\"chemistry\",\"earth and planetary\",\"computer science\"]):\n","        return \"Exatas\"\n","    if \"engineering\" in x or \"materials science\" in x:\n","        return \"Engenharias\"\n","    if \"biology\" in x or \"biological\" in x:\n","        return \"Biológicas\"\n","    if \"medicine\" in x or \"health\" in x or \"nursing\" in x or \"public health\" in x:\n","        return \"Saúde\"\n","    if \"psychology\" in x or \"humanities\" in x or \"philosophy\" in x or \"history\" in x:\n","        return \"Humanas\"\n","    if \"economics\" in x or \"business\" in x or \"management\" in x or \"political science\" in x or \"law\" in x:\n","        return \"Sociais Aplicadas\"\n","    if \"linguistics\" in x or \"arts\" in x or \"literature\" in x:\n","        return \"Linguística, Letras e Artes\"\n","    return \"Multidisciplinar\"\n","\n","def normaliza_sub(x):\n","    if pd.isna(x):\n","        return \"\"\n","    x = str(x).lower().strip()\n","    x = unicodedata.normalize(\"NFKD\", x).encode(\"ascii\",\"ignore\").decode(\"utf-8\")\n","    return x\n","\n","# -------- Load original --------\n","df = pd.read_excel(INPUT_FILENAME)\n","\n","# -------- 1) Renomear colunas (se existirem) --------\n","rename_map = {\n","    \"Pesquisador_nome\": \"pesquisador\",\n","    \"Regiao_Geografica\": \"regiao_geografica\",\n","    \"Sigla_UF\": \"sigla_uf\",\n","    \"Ano(s) do edital (Chamada)\": \"ano_chamada\",\n","    \"Período(s) de vigência\": \"periodo_vigencia\",\n","    \"Class_Instituicao\": \"class_instituicao\",\n","    \"Inst_categoria\": \"inst_categoria\",\n","    \"CATEGORIA_ADMINISTRATIVA\": \"categoria_administrativa\",\n","    \"grande_area_openalex\": \"grande_area\",\n","    \"area_openalex\": \"area\",\n","    \"inst_IGC_faixa\": \"igc_faixa\"\n","}\n","df = df.rename(columns={k:v for k,v in rename_map.items() if k in df.columns})\n","\n","# Garantir colunas essenciais\n","for col_min in [\"pesquisador\",\"inst_norm\",\"class_instituicao\",\"categoria_administrativa\",\"sigla_uf\",\"regiao_geografica\",\n","                \"ano_chamada\",\"periodo_vigencia\",\"h_index\",\"area\",\"igc_faixa\"]:\n","    if col_min not in df.columns:\n","        df[col_min] = np.nan\n","\n","# -------- 2) IDs --------\n","df[\"id_pesq\"] = df[\"pesquisador\"].apply(normalize_ascii_lower).factorize()[0] + 1\n","df[\"id_inst\"] = df[\"inst_norm\"].apply(normalize_ascii_lower).factorize()[0] + 1\n","\n","# -------- 3) UF & Região (original e corrigidas) --------\n","df[\"uf_original\"] = df.get(\"sigla_uf\")\n","df[\"regiao_original\"] = df.get(\"regiao_geografica\")\n","\n","df[\"uf_corrigida\"] = df[\"uf_original\"].apply(corrige_uf)\n","df[\"regiao_corrigida\"] = df[\"uf_corrigida\"].map(mapa_regiao)\n","\n","# -------- 4) tipo_ies (macro) --------\n","df[\"tipo_ies\"] = df.apply(lambda r: tipo_ies_row(r.get(\"class_instituicao\"), r.get(\"categoria_administrativa\")), axis=1)\n","\n","# -------- 5) grupo IF + CEFT --------\n","df[\"grupo_if_ceft\"] = df[\"class_instituicao\"].astype(str).str.upper().apply(lambda x: 1 if (\"INSTITUTO FEDERAL\" in x or \"CEFT\" in x) else 0)\n","\n","# -------- 6) IGC categoria --------\n","df[\"igc_categoria\"] = df[\"igc_faixa\"].apply(igc_categoria_val)\n","\n","# -------- 7) num_chamadas_participou --------\n","df[\"num_chamadas_participou\"] = df.groupby(\"pesquisador\")[\"ano_chamada\"].transform(\"nunique\")\n","\n","# -------- 8) dummies de chamadas --------\n","if \"ano_chamada\" in df.columns:\n","    dummies = pd.get_dummies(df[\"ano_chamada\"], prefix=\"ch\")\n","    df = pd.concat([df, dummies], axis=1)\n","\n","# -------- 9) nivel_producao --------\n","df[\"nivel_producao\"] = df[\"h_index\"].apply(nivel_producao_val)\n","\n","# -------- 10) área macro e sub --------\n","df[\"area_macro\"] = df[\"area\"].apply(area_macro_from_area)\n","df[\"area_sub\"] = df[\"area\"].apply(normaliza_sub)\n","\n","# -------- 11) Dicionário de dados --------\n","desc_map = {\n","    \"pesquisador\":\"Nome do pesquisador (string padronizada)\",\n","    \"inst_norm\":\"Nome normalizado da instituição\",\n","    \"class_instituicao\":\"Classificação da instituição (INSTITUTO DE PESQUISA, CEFT, IES, INSTITUTO FEDERAL, OUTROS)\",\n","    \"categoria_administrativa\":\"Categoria administrativa (e-MEC): federal, estadual, municipal, privada com/sem fins\",\n","    \"sigla_uf\":\"UF informada originalmente\",\n","    \"regiao_geografica\":\"Região informada originalmente\",\n","    \"uf_corrigida\":\"UF corrigida (normalizada)\",\n","    \"regiao_corrigida\":\"Região corrigida a partir da UF\",\n","    \"ano_chamada\":\"Identificador da chamada (ex.: 2014-2016)\",\n","    \"periodo_vigencia\":\"Período(s) de vigência listados para o pesquisador\",\n","    \"n_chamada\":\"Número/ordem da chamada no período\",\n","    \"h_index\":\"Índice h (OpenAlex)\",\n","    \"i10_index\":\"Índice i10 (OpenAlex)\",\n","    \"works_count\":\"Total de trabalhos (OpenAlex)\",\n","    \"cited_by_count\":\"Total de citações (OpenAlex)\",\n","    \"grande_area\":\"Grande área (OpenAlex)\",\n","    \"area\":\"Área (OpenAlex)\",\n","    \"area_macro\":\"Área macro (simplificada para análise)\",\n","    \"area_sub\":\"Subárea normalizada (derivada de 'area')\",\n","    \"igc_faixa\":\"Faixa do IGC (INEP)\",\n","    \"igc_categoria\":\"Categoria do IGC (Alto/Médio/Baixo/Sem IGC)\",\n","    \"tipo_ies\":\"Macro-categoria institucional (pública/privada/etc.)\",\n","    \"grupo_if_ceft\":\"Indicador (1=IF ou CEFT; 0=demais)\",\n","    \"num_chamadas_participou\":\"Número de chamadas em que o pesquisador participou\",\n","    \"id_pesq\":\"ID único do pesquisador (estável por nome normalizado)\",\n","    \"id_inst\":\"ID único da instituição (estável por nome normalizado)\"\n","}\n","dic_rows = []\n","for col in df.columns:\n","    desc = desc_map.get(col, \"Descrição pendente\")\n","    tipo = str(df[col].dtype)\n","    dic_rows.append({\"variavel\": col, \"descricao\": desc, \"tipo\": tipo})\n","dic = pd.DataFrame(dic_rows)\n","\n","# -------- 12) Salvar XLSX --------\n","OUTPUT_FILENAME = \"PIBIC_EM_BASE_PADRONIZADO.xlsx\"\n","with pd.ExcelWriter(OUTPUT_FILENAME, engine=\"openpyxl\") as writer:\n","    df.to_excel(writer, sheet_name=\"base_limpa\", index=False)\n","    dic.to_excel(writer, sheet_name=\"dicionario_de_dados\", index=False)\n","\n","print(\"Gerado:\", OUTPUT_FILENAME)\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"IoyHNtpTNp4b","executionInfo":{"status":"ok","timestamp":1762701784439,"user_tz":300,"elapsed":2866,"user":{"displayName":"Tiago Anjos","userId":"11164892913379647325"}},"outputId":"24051396-d98f-4e57-e027-12f29a3effe5"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Gerado: PIBIC_EM_BASE_PADRONIZADO.xlsx\n"]}]}]}