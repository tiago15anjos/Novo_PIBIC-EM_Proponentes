{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNlmhQ5Z3yURwq2j28+b54i"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":3,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"7H_lfd1yAxoE","executionInfo":{"status":"ok","timestamp":1765819403258,"user_tz":300,"elapsed":7755,"user":{"displayName":"Tiago Anjos","userId":"11164892913379647325"}},"outputId":"c6b2f675-c0a0-450f-b393-ba3d61a26374"},"outputs":[{"output_type":"stream","name":"stdout","text":["Gerando Gráficos Regionais de Área (PT)...\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x800 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x700 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["import pandas as pd\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","from scipy.stats import chi2_contingency\n","from matplotlib import rcParams\n","\n","# Configuração Estética\n","plt.rcParams.update(plt.rcParamsDefault)\n","rcParams['font.family'] = 'sans-serif'\n","rcParams['font.sans-serif'] = ['Arial', 'DejaVu Sans', 'Liberation Sans']\n","rcParams['font.size'] = 11\n","rcParams['axes.spines.top'] = False\n","rcParams['axes.spines.right'] = False\n","rcParams['legend.frameon'] = False\n","\n","# 1. Carregar Dados\n","try:\n","    nome_arquivo = \"2025_11_20_participacao_PIBIC-EM_categoria_adm_corrigida_v4.csv\"\n","    df = pd.read_csv(nome_arquivo)\n","\n","    # Filtros e Limpeza\n","    col_reg = 'regiao_corrigida'\n","    col_area = 'grande_area - area_macro_CAPES'\n","\n","    df = df.dropna(subset=[col_reg, col_area])\n","    df = df[df[col_area] != 'Não aplicável']\n","\n","    # Mapeamento para nomes curtos (PT)\n","    mapa_areas = {\n","        'Ciências Exatas e da Terra': 'Exatas',\n","        'Ciências Biológicas': 'Biológicas',\n","        'Engenharias': 'Engenharias',\n","        'Ciências da Saúde': 'Saúde',\n","        'Ciências Agrárias': 'Agrárias',\n","        'Ciências Sociais Aplicadas': 'Sociais',\n","        'Ciências Humanas': 'Humanas',\n","        'Linguística, Letras e Artes': 'Artes/Letras',\n","        'Multidisciplinar': 'Multi'\n","    }\n","    df['area_plot'] = df[col_area].map(mapa_areas).fillna(df[col_area])\n","\n","except Exception as e:\n","    print(f\"Erro ao carregar dados: {e}\")\n","    df = pd.DataFrame()\n","\n","# ==============================================================================\n","# VISUALIZAÇÃO 1: HEATMAP DE RESÍDUOS (ÁREA x REGIÃO)\n","# ==============================================================================\n","def get_adj_residuals(data, col_x, col_y):\n","    ct = pd.crosstab(data[col_y], data[col_x])\n","    observed = ct.values\n","    chi2, p, dof, expected = chi2_contingency(observed)\n","\n","    with np.errstate(divide='ignore', invalid='ignore'):\n","        n = observed.sum()\n","        row_p = observed.sum(axis=1) / n\n","        col_p = observed.sum(axis=0) / n\n","        div = np.sqrt(expected * (1 - row_p[:, np.newaxis]) * (1 - col_p[np.newaxis, :]))\n","        adj_res = (observed - expected) / div\n","\n","    return pd.DataFrame(adj_res, index=ct.index, columns=ct.columns).fillna(0)\n","\n","def plot_heatmap_regional_areas_pt():\n","    residuos = get_adj_residuals(df, col_reg, 'area_plot')\n","\n","    # Ordenação\n","    ordem_reg = ['Norte', 'Nordeste', 'Centro-Oeste', 'Sudeste', 'Sul']\n","    ordem_areas = ['Exatas', 'Biológicas', 'Engenharias', 'Saúde',\n","                   'Sociais', 'Humanas', 'Artes/Letras', 'Multi']\n","\n","    residuos = residuos.reindex(index=ordem_areas, columns=ordem_reg)\n","\n","    fig, ax = plt.subplots(figsize=(10, 8))\n","\n","    # Heatmap \"Limpo\": Foco nos valores extremos\n","    # Usamos vmin/vmax -4 a 4 para dar contraste, mas a nota explica o corte 1.96\n","    sns.heatmap(residuos, annot=True, fmt=\".2f\", cmap=\"vlag\", center=0, vmin=-4, vmax=4,\n","                linewidths=1, linecolor='white', cbar_kws={'label': 'Resíduos Padronizados Ajustados (z)', 'shrink': 0.7}, ax=ax)\n","\n","    ax.set_xlabel(\"Região\", weight='bold', fontsize=11, labelpad=10)\n","    ax.set_ylabel(\"Grande Área\", weight='bold', fontsize=11, labelpad=10)\n","    plt.yticks(rotation=0)\n","\n","    fig.text(0.02, 0.96, \"Figura 43\", fontsize=12, weight='bold')\n","    fig.text(0.02, 0.93, \"Padrões Regionais de Especialização Disciplinar (Heatmap)\", fontsize=12, style='italic')\n","\n","    note = (r\"$\\it{Nota.}$ Valores $|z| > 1.96$ indicam associações significativas. \"\n","            \"Destaque para a concentração de 'Biológicas' no Centro-Oeste (+2.88) e Norte (+2.28), \"\n","            \"e o déficit de 'Humanas' no Centro-Oeste (-2.61).\")\n","    fig.text(0.02, 0.01, note, fontsize=10, ha='left', wrap=True)\n","\n","    plt.tight_layout(rect=[0, 0.08, 1, 0.92])\n","    plt.savefig(\"apa_fig43_heatmap_regional_areas_PT.png\", dpi=300, bbox_inches='tight')\n","    plt.show()\n","\n","# ==============================================================================\n","# VISUALIZAÇÃO 2: BARRAS EMPILHADAS 100% (REGIÃO)\n","# ==============================================================================\n","def plot_stacked_regional_areas_pt():\n","    ct = pd.crosstab(df[col_reg], df['area_plot'], normalize='index') * 100\n","\n","    # Ordenação Regional\n","    ordem_reg = ['Norte', 'Nordeste', 'Centro-Oeste', 'Sudeste', 'Sul']\n","    ct = ct.reindex(ordem_reg)\n","\n","    # Ordenação de Áreas (Para consistência visual nas barras)\n","    ordem_cols = ['Exatas', 'Biológicas', 'Engenharias', 'Saúde',\n","                  'Sociais', 'Humanas', 'Artes/Letras', 'Multi']\n","    ct = ct.reindex(columns=[c for c in ordem_cols if c in ct.columns])\n","\n","    fig, ax = plt.subplots(figsize=(12, 7))\n","\n","    # Paleta Distinta para Áreas (Muitas categorias)\n","    # Usando tab20 ou similar para diferenciar\n","    cmap = plt.get_cmap('tab20')\n","    colors = [cmap(i) for i in np.linspace(0, 1, len(ct.columns))]\n","\n","    ct.plot(kind='bar', stacked=True, width=0.85, color=colors, ax=ax, edgecolor='white', linewidth=0.5)\n","\n","    # Rótulos (> 4%)\n","    for c in ax.containers:\n","        labels = [f'{v.get_height():.0f}%' if v.get_height() > 4 else '' for v in c]\n","        ax.bar_label(c, labels=labels, label_type='center', fontsize=9, color='white', weight='bold')\n","\n","    ax.set_xlabel(\"Região Geográfica\", weight='bold', fontsize=11, labelpad=10)\n","    ax.set_ylabel(\"Composição por Grande Área (%)\", fontsize=11)\n","    ax.set_ylim(0, 100)\n","    plt.xticks(rotation=0, ha='center')\n","\n","    # Legenda Externa\n","    ax.legend(title=\"Grande Área\", bbox_to_anchor=(1.02, 1), loc='upper left', frameon=False, fontsize=9)\n","\n","    fig.text(0.02, 0.98, \"Figura 44\", fontsize=12, weight='bold')\n","    fig.text(0.02, 0.95, \"Perfil Disciplinar por Região (Composição Percentual)\", fontsize=12, style='italic')\n","\n","    note = (r\"$\\it{Nota.}$ O gráfico mostra como as áreas se distribuem dentro de cada região. \"\n","            \"Observe a fatia maior de Biológicas (cor correspondente) no Norte/CO em comparação ao Sudeste.\")\n","    fig.text(0.02, -0.05, note, fontsize=10, ha='left', wrap=True)\n","\n","    plt.tight_layout(rect=[0, 0, 1, 0.92])\n","    plt.savefig(\"apa_fig44_stacked_regional_areas_PT.png\", dpi=300, bbox_inches='tight')\n","    plt.show()\n","\n","print(\"Gerando Gráficos Regionais de Área (PT)...\")\n","plot_heatmap_regional_areas_pt()\n","plot_stacked_regional_areas_pt()"]},{"cell_type":"code","source":["# ==============================================================================\n","# VERSÃO INGLÊS (EN)\n","# ==============================================================================\n","def plot_heatmap_regional_areas_en():\n","    # Mapeamentos EN\n","    mapa_reg_en = {'Norte': 'North', 'Nordeste': 'Northeast', 'Centro-Oeste': 'Central-West',\n","                   'Sudeste': 'Southeast', 'Sul': 'South'}\n","    mapa_areas_en = {\n","        'Ciências Exatas e da Terra': 'Exact Sci.', 'Ciências Biológicas': 'Bio. Sci.',\n","        'Engenharias': 'Engineering', 'Ciências da Saúde': 'Health',\n","        'Ciências Agrárias': 'Agrarian', 'Ciências Sociais Aplicadas': 'Soc. Sci.',\n","        'Ciências Humanas': 'Humanities', 'Linguística, Letras e Artes': 'Arts/Ling.',\n","        'Multidisciplinar': 'Multi'\n","    }\n","\n","    df_en = df.copy()\n","    df_en['reg_en'] = df_en[col_reg].map(mapa_reg_en)\n","    df_en['area_en'] = df_en[col_area].map(mapa_areas_en).fillna('Other')\n","\n","    residuos = get_adj_residuals(df_en, 'reg_en', 'area_en')\n","\n","    ordem_reg = ['North', 'Northeast', 'Central-West', 'Southeast', 'South']\n","    ordem_areas = ['Exact Sci.', 'Bio. Sci.', 'Engineering', 'Health',\n","                   'Soc. Sci.', 'Humanities', 'Arts/Ling.', 'Multi']\n","\n","    residuos = residuos.reindex(index=ordem_areas, columns=ordem_reg)\n","\n","    fig, ax = plt.subplots(figsize=(10, 8))\n","    sns.heatmap(residuos, annot=True, fmt=\".2f\", cmap=\"vlag\", center=0, vmin=-4, vmax=4,\n","                linewidths=1, linecolor='white', cbar_kws={'label': 'Adj. Standardized Residuals (z)', 'shrink': 0.7}, ax=ax)\n","\n","    ax.set_xlabel(\"Region\", weight='bold', fontsize=11, labelpad=10)\n","    ax.set_ylabel(\"Major Knowledge Area\", weight='bold', fontsize=11, labelpad=10)\n","    plt.yticks(rotation=0)\n","\n","    fig.text(0.02, 0.96, \"Figure 43\", fontsize=12, weight='bold')\n","    fig.text(0.02, 0.93, \"Regional Patterns of Disciplinary Specialization (Heatmap)\", fontsize=12, style='italic')\n","\n","    note = (r\"$\\it{Note.}$ Values $|z| > 1.96$ indicate significant associations. \"\n","            \"Highlight on the concentration of 'Bio. Sci.' in Central-West (+2.88) and North (+2.28), \"\n","            \"and the deficit of 'Humanities' in Central-West (-2.61).\")\n","    fig.text(0.02, 0.01, note, fontsize=10, ha='left', wrap=True)\n","\n","    plt.tight_layout(rect=[0, 0.08, 1, 0.92])\n","    plt.savefig(\"apa_fig43_heatmap_regional_areas_EN.png\", dpi=300, bbox_inches='tight')\n","    plt.show()\n","\n","def plot_stacked_regional_areas_en():\n","    # Usar df_en criado na função anterior (recriar para escopo local)\n","    mapa_reg_en = {'Norte': 'North', 'Nordeste': 'Northeast', 'Centro-Oeste': 'Central-West',\n","                   'Sudeste': 'Southeast', 'Sul': 'South'}\n","    mapa_areas_en = {\n","        'Ciências Exatas e da Terra': 'Exact Sci.', 'Ciências Biológicas': 'Bio. Sci.',\n","        'Engenharias': 'Eng.', 'Ciências da Saúde': 'Health',\n","        'Ciências Agrárias': 'Agrarian', 'Ciências Sociais Aplicadas': 'Soc. Sci.',\n","        'Ciências Humanas': 'Humanities', 'Linguística, Letras e Artes': 'Arts/Ling.',\n","        'Multidisciplinar': 'Multi'\n","    }\n","    df['reg_en'] = df[col_reg].map(mapa_reg_en)\n","    df['area_en'] = df[col_area].map(mapa_areas_en).fillna('Other')\n","\n","    ct = pd.crosstab(df['reg_en'], df['area_en'], normalize='index') * 100\n","\n","    ordem_reg = ['North', 'Northeast', 'Central-West', 'Southeast', 'South']\n","    ct = ct.reindex(ordem_reg)\n","\n","    ordem_cols = ['Exact Sci.', 'Bio. Sci.', 'Eng.', 'Health',\n","                  'Soc. Sci.', 'Humanities', 'Arts/Ling.', 'Multi']\n","    ct = ct.reindex(columns=[c for c in ordem_cols if c in ct.columns])\n","\n","    fig, ax = plt.subplots(figsize=(12, 7))\n","    cmap = plt.get_cmap('tab20')\n","    colors = [cmap(i) for i in np.linspace(0, 1, len(ct.columns))]\n","\n","    ct.plot(kind='bar', stacked=True, width=0.85, color=colors, ax=ax, edgecolor='white', linewidth=0.5)\n","\n","    for c in ax.containers:\n","        labels = [f'{v.get_height():.0f}%' if v.get_height() > 4 else '' for v in c]\n","        ax.bar_label(c, labels=labels, label_type='center', fontsize=9, color='white', weight='bold')\n","\n","    ax.set_xlabel(\"Geographic Region\", weight='bold', fontsize=11, labelpad=10)\n","    ax.set_ylabel(\"Composition by Major Area (%)\", fontsize=11)\n","    ax.set_ylim(0, 100)\n","    plt.xticks(rotation=0, ha='center')\n","\n","    ax.legend(title=\"Major Area\", bbox_to_anchor=(1.02, 1), loc='upper left', frameon=False, fontsize=9)\n","\n","    fig.text(0.02, 0.98, \"Figure 44\", fontsize=12, weight='bold')\n","    fig.text(0.02, 0.95, \"Disciplinary Profile by Region (Percentage Composition)\", fontsize=12, style='italic')\n","\n","    note = (r\"$\\it{Note.}$ The chart shows how knowledge areas are distributed within each region. \"\n","            \"Note the larger slice of Bio. Sci. in North/Central-West compared to Southeast.\")\n","    fig.text(0.02, -0.05, note, fontsize=10, ha='left', wrap=True)\n","\n","    plt.tight_layout(rect=[0, 0, 1, 0.92])\n","    plt.savefig(\"apa_fig44_stacked_regional_areas_EN.png\", dpi=300, bbox_inches='tight')\n","    plt.show()\n","\n","print(\"Gerando Gráficos Regionais de Área (EN)...\")\n","plot_heatmap_regional_areas_en()\n","plot_stacked_regional_areas_en()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"SSF1AgZtDGNc","executionInfo":{"status":"ok","timestamp":1765819610498,"user_tz":300,"elapsed":9666,"user":{"displayName":"Tiago Anjos","userId":"11164892913379647325"}},"outputId":"6bb9bdf8-c173-4bad-bf83-40096a167a7e"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["Gerando Gráficos Regionais de Área (EN)...\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x800 with 2 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x700 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]}]}