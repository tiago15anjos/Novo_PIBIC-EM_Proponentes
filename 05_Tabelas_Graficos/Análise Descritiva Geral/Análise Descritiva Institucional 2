L_REC, values=\"pct\", fill_value=0)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import pandas as pd\n","import plotly.graph_objects as go\n","\n","# ==============================================================================\n","# 1. CARREGAMENTO E PROCESSAMENTO (v5)\n","# ==============================================================================\n","ARQ = \"2025_12_18_participacao_PIBIC-EM_categoria_adm_corrigida_v5.csv\"\n","\n","try:\n","    df = pd.read_csv(ARQ, low_memory=False)\n","\n","    COL_TIPO = \"categoria_adm_corrigida\"\n","    COL_REC  = \"Categoria_Recorrencia\"\n","\n","    # Limpeza\n","    for c in [COL_TIPO, COL_REC]:\n","        df[c] = df[c].astype(\"string\").str.strip()\n","    df = df.dropna(subset=[COL_TIPO, COL_REC])\n","\n","    # 1. Mapeamento de Nomes (Simplificados)\n","    mapa_nomes = {\n","        'Universidade Federal': 'Univ. Federal',\n","        'IF/CEFET': 'IF/CEFET',\n","        'PUBLICA ESTADUAL': 'IES Estadual',\n","        'PRIVADA COM FINS LUCRATIVOS': 'IES Privada c/ Fins',\n","        'PRIVADA SEM FINS LUCRATIVOS': 'IES Privada s/ Fins',\n","        'INSTITUTO DE PESQUISA': 'Inst. Pesquisa',\n","        'IES PUBLICA MUNICIPAL': 'Outros',\n","        'FUNDACAO PUBLICA': 'Outros',\n","        'ORGANIZACAO SOCIAL': 'Outros',\n","        'ORGAO PUBLICO': 'Outros',\n","        'ESPECIAL': 'Outros'\n","    }\n","    df['source_label'] = df[COL_TIPO].map(lambda x: mapa_nomes.get(x, 'Outros'))\n","\n","    # 2. Ordenação da Recorrência (Destino)\n","    unique_rec = df[COL_REC].unique()\n","    if any('1 (' in str(s) for s in unique_rec):\n","        target_order = ['1 (Pontual)', '2-3 (Intermediária)', '4+ (Consolidada)']\n","    elif 'Pontual' in unique_rec:\n","        target_order = [\"Pontual\", \"Intermediário\", \"Recorrente\"]\n","    else:\n","        target_order = sorted([x for x in unique_rec if pd.notna(x)])\n","\n","    # 3. Agregação\n","    sankey_df = df.groupby(['source_label', COL_REC]).size().reset_index(name='value')\n","    sankey_df = sankey_df[sankey_df['value'] > 0]\n","\n","    # ==========================================================================\n","    # 2. IMPLEMENTAÇÃO DA ORDENAÇÃO PERSONALIZADA (SEU PEDIDO)\n","    # ==========================================================================\n","\n","    desired_source_order = [\n","        'Univ. Federal',\n","        'IF/CEFET',\n","        'IES Estadual',\n","        'IES Privada s/ Fins',\n","        'IES Privada c/ Fins',\n","        'Inst. Pesquisa',\n","        'Outros'\n","    ]\n","\n","    # Obter fontes presentes nos dados\n","    present_sources = list(sankey_df['source_label'].unique())\n","\n","    # Ordenar fontes presentes com base na lista de desejo\n","    all_sources = sorted(\n","        present_sources,\n","        key=lambda x: desired_source_order.index(x) if x in desired_source_order else 999\n","    )\n","\n","    all_targets = target_order\n","    label_list = all_sources + all_targets # Lista ordenada final\n","\n","    # Mapear índices\n","    source_indices = [label_list.index(s) for s in sankey_df['source_label']]\n","    target_indices = [label_list.index(t) for t in sankey_df[COL_REC]]\n","    values = sankey_df['value'].tolist()\n","\n","    # ==========================================================================\n","    # 3. CONFIGURAÇÃO DE CORES\n","    # ==========================================================================\n","\n","    node_colors = ['#555'] * len(all_sources)\n","\n","    if len(target_order) == 3:\n","        target_colors = ['#bdc9e1', '#74a9cf', '#0570b0'] # Claro -> Escuro\n","    else:\n","        target_colors = ['#0570b0'] * len(all_targets)\n","\n","    node_colors += target_colors\n","\n","    color_map = dict(zip(target_order, target_colors)) if len(target_order) == 3 else {}\n","\n","    link_colors = []\n","    for t in sankey_df[COL_REC]:\n","        c = color_map.get(t, '#999')\n","        if c.startswith('#'):\n","            h = c.lstrip('#')\n","            rgb = tuple(int(h[i:i+2], 16) for i in (0, 2, 4))\n","            link_colors.append(f'rgba({rgb[0]},{rgb[1]},{rgb[2]},0.6)')\n","        else:\n","            link_colors.append(c)\n","\n","    # ==========================================================================\n","    # 4. PLOTAGEM\n","    # ==========================================================================\n","\n","    fig = go.Figure(data=[go.Sankey(\n","        node = dict(\n","            pad = 20,\n","            thickness = 20,\n","            line = dict(color = \"white\", width = 0.5),\n","            label = label_list,\n","            color = node_colors,\n","            hovertemplate='<b>%{label}</b><br>Total: %{value} pesquisadores<extra></extra>'\n","        ),\n","        link = dict(\n","            source = source_indices,\n","            target = target_indices,\n","            value  = values,\n","            color  = link_colors,\n","            hovertemplate='%{source.label} → %{target.label}<br>%{value} pesquisadores<extra></extra>'\n","        )\n","    )])\n","\n","    # Layout Estilo APA\n","    fig.update_layout(\n","        title_text=\"<b>Figura [U]</b><br><i>Fluxo de Participação (Ordenado por Tipo Institucional)</i>\",\n","        title_font_family=\"Arial\",\n","        title_font_size=14,\n","        font_family=\"Arial\",\n","        font_size=12,\n","        plot_bgcolor='white',\n","        paper_bgcolor='white',\n","        width=900,\n","        height=600,\n","        margin=dict(l=50, r=50, t=80, b=80)\n","    )\n","\n","    fig.add_annotation(\n","        text=\"<i>Nota.</i> A ordem vertical das fontes segue a hierarquia: Federal > IF > Estadual > Privadas > Pesquisa.<br>Observe a predominância do fluxo 'Federal' para a recorrência consolidada.\",\n","        xref=\"paper\", yref=\"paper\",\n","        