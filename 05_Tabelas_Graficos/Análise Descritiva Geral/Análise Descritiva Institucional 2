orrencia\"\n","\n","    # Limpeza\n","    for c in [COL_REG, COL_TIPO, COL_REC]:\n","        df[c] = df[c].astype(\"string\").str.strip()\n","    df = df.dropna(subset=[COL_REG, COL_TIPO, COL_REC])\n","\n","    # Mapeamento de Nomes\n","    mapa_nomes = {\n","        'Universidade Federal': 'Univ. Federal',\n","        'IF/CEFET': 'IF/CEFET',\n","        'PUBLICA ESTADUAL': 'Univ. Estadual',\n","        'PRIVADA COM FINS LUCRATIVOS': 'Privada c/ Fins',\n","        'PRIVADA SEM FINS LUCRATIVOS': 'Privada s/ Fins',\n","        'IES PUBLICA MUNICIPAL': 'IES Municipal',\n","        'INSTITUTO DE PESQUISA': 'Inst. Pesquisa'\n","    }\n","    df['adm_label'] = df[COL_TIPO].map(mapa_nomes)\n","\n","    # Filtro Categorias\n","    df_filtered = df.dropna(subset=['adm_label']).copy()\n","\n","    # Identificar a categoria \"Recorrente\" (Maior Fidelidade)\n","    unique_vals = df_filtered[COL_REC].unique()\n","    target_rec = None\n","\n","    # Busca pela string que indica fidelidade máxima\n","    candidates = ['4+ (Consolidada)', 'Recorrente', 'Consolidada', 'Alta']\n","    for cand in candidates:\n","        if cand in unique_vals:\n","            target_rec = cand\n","            break\n","\n","    if target_rec is None:\n","         # Fallback: pega o último valor se estiver ordenado alfabeticamente/numericamente\n","         target_rec = sorted(unique_vals)[-1]\n","\n","    # Filtrar APENAS os Recorrentes\n","    df_rec = df_filtered[df_filtered[COL_REC] == target_rec].copy()\n","\n","    # Agregação\n","    tab_rec = (\n","        df_rec\n","        .groupby([COL_REG, 'adm_label'])\n","        .size()\n","        .reset_index(name=\"n_recorrentes\")\n","    )\n","\n","    # Pivot Table\n","    pivot_rec = tab_rec.pivot_table(index=COL_REG, columns='adm_label', values=\"n_recorrentes\", fill_value=0)\n","\n","    # Ordenação\n","    ordem_reg = ['Norte', 'Nordeste', 'Centro-Oeste', 'Sudeste', 'Sul']\n","    pivot_rec = pivot_rec.reindex(index=[r for r in ordem_reg if r in pivot_rec.index])\n","\n","    desired_cols = ['Univ. Federal', 'IF/CEFET', 'Univ. Estadual', 'Privada s/ Fins', 'Privada c/ Fins', 'Inst. Pesquisa']\n","    pivot_rec = pivot_rec.reindex(columns=[c for c in desired_cols if c in pivot_rec.columns])\n","\n","except Exception as e:\n","    print(f\"Erro: {e}\")\n","    pivot_rec = pd.DataFrame()\n","    target_rec = \"Recorrente\"\n","\n","# ==============================================================================\n","# 3. PLOTAGEM (COM SETAS PARA N PEQUENO)\n","# ==============================================================================\n","def plot_recurrent_volume_arrows():\n","    fig, ax = plt.subplots(figsize=(10, 6))\n","\n","    # Cores (Tab10 para Categorias)\n","    colors = plt.cm.tab10.colors\n","\n","    # Plot Stacked Bar\n","    pivot_rec.plot(kind='bar', stacked=True, ax=ax, color=colors, width=0.7, edgecolor='white')\n","\n","    # === LÓGICA DAS SETAS ===\n","    THRESHOLD = 0\n","    ARROW_OFFSET_X = 25\n","    ARROW_OFFSET_Y = 0\n","    ARROW_COLOR = '#333'\n","\n","    for c in ax.containers:\n","        # Rótulos Internos (> THRESHOLD)\n","        labels_inside = [f'{int(v.get_height())}' if v.get_height() > THRESHOLD else '' for v in c]\n","        ax.bar_label(c, labels=labels_inside, label_type='center', fontsize=9, color='white', weight='bold')\n","\n","        # Setas Externas (<= THRESHOLD)\n","        for rect in c:\n","            h = rect.get_height()\n","            if 0 < h <= THRESHOLD:\n","                center_x = rect.get_x() + rect.get_width() / 2\n","                center_y = rect.get_y() + h / 2\n","                ax.annotate(\n","                    f'{int(h)}',\n","                    xy=(center_x, center_y),\n","                    xytext=(ARROW_OFFSET_X, ARROW_OFFSET_Y),\n","                    textcoords='offset points',\n","                    ha='left', va='center',\n","                    fontsize=9, color=ARROW_COLOR, weight='bold',\n","                    arrowprops=dict(arrowstyle='->', color=ARROW_COLOR, lw=0.8, shrinkA=0, shrinkB=0)\n","                )\n","\n","    # Estilo\n","    ax.set_xlabel(\"Região\", fontsize=11, weight='bold', labelpad=10)\n","    ax.set_ylabel(\"Número de Proponentes (Recorrentes)\", fontsize=11, weight='bold', labelpad=10)\n","    ax.tick_params(axis='x', rotation=0)\n","\n","    ax.legend(title=\"Tipo Institucional\", bbox_to_anchor=(1.02, 1), loc='upper left', frameon=False)\n","\n","    # Títulos APA\n","    fig.text(0.02, 0.98, \"Figura [T]\", fontsize=12, weight='bold')\n","    # Título dinâmico com o nome da categoria filtrada\n","    fig.text(0.02, 0.94, f\"Concentração de Proponentes Recorrentes ({target_rec}) por Tipo e Região\", fontsize=12, style='italic')\n","\n","    # Nota\n","    note = (r\"$\\it{Nota.}$ O gráfico isola os pesquisadores da categoria de maior fidelidade ('Consolidada'). \")\n","    fig.text(0.02, 0.01, note, fontsize=10, ha='left', wrap=True)\n","\n","    plt.tight_layout(rect=[0, 0.08, 1, 0.93])\n","    plt.savefig(\"volume_recorrentes_arrow_v5.png\", dpi=300, bbox_inches='tight')\n","    plt.show()\n","\n","plot_recurrent_volume_arrows()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":551},"id":"rqblBKWI-y6V","executionInfo":{"status":"ok","timestamp":1766086988446,"user_tz":300,"elapsed":2122,"user":{"displayName":"Tiago Anjos","userId":"11164892913379647325"}},"outputId":"91280b4d-5f13-407d-9b90-5f1394a2bc97"},"execution_count":39,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["import pandas as pd\n","import matplotlib.pyplot as plt\n","from matplotlib import rcParams\n","\n","# ==============================================================================\n","# 1. CONFIGURAÇÃO ESTÉTICA (APA)\n","# ==============================================================================\n","plt.rcParams.update(plt.rcParamsDefault)\n","rcParams['font.family'] = 'sans-serif'\n","rcParams['font.sans-serif'] = ['Arial', 'DejaVu Sans', 'Liberation Sans']\n","rcParams['font.size'] = 11\n","rcParams['axes.spines.top'] = False\n","rcParams['axes.spines.right'] = False\n","rcParams['legend.frameon'] = False\n","\n","# ==============================================================================\n","# 2. PROCESSAMENTO DE DADOS (v5)\n","# ==============================================================================\n","ARQ = \"2025_12_18_participacao_PIBIC-EM_categoria_adm_corrigida_v5.csv\"\n","\n","try:\n","    df = pd.read_csv(ARQ, low_memory=False)\n","\n","    COL_TIPO = \"categoria_adm_corrigida\"\n","    COL_REG  = \"regiao_corrigida\"\n","    COL_REC  = \"Categoria_Recorrencia\"\n","\n","    # Limpeza\n","    for c in [COL_TIPO, COL_REG, COL_REC]:\n","        df[c] = df[c].astype(\"string\").str.strip()\n","    df = df.dropna(subset=[COL_TIPO, COL_REG, COL_REC])\n","\n","    # === LÓGICA DE AGRUPAMENTO (3 GRUPOS) ===\n","    def agrupar_tipo(x):\n","        x = str(x).lower()\n","        if \"federal\" in x and \"univers\" in x:\n","            return \"Univ. Federais\"\n","        if \"if\" in x or \"cefet\" in x or \"instituto federal\" in x:\n","            return \"IFs/CEFETs\"\n","        return \"Outros tipos\"\n","\n","    df[\"tipo_3grupos\"] = df[COL_TIPO].apply(agrupar_tipo)\n","\n","    # Definir Ordem da Recorrência\n","    unique_rec = df[COL_REC].unique()\n","    # Tenta detectar a nomenclatura exata do arquivo v5\n","    if any('1 (' in str(s) for s in unique_rec):\n","        ordem_rec = ['1 (Pontual)', '2-3 (Intermediária)', '4+ (Consolidada)']\n","    else:\n","        # Fallback para nomes genéricos se houver mudança\n","        ordem_rec = sorted(unique_rec)\n","\n","    # Agregação\n","    tab3 = (\n","        df\n","        .groupby([COL_REG, \"tipo_3grupos\", COL_REC])\n","        .size()\n","        .reset_index(name=\"n\")\n","    )\n","\n","    # Cálculo do Percentual\n","    tab3[\"pct\"] = tab3.groupby([COL_REG, \"tipo_3grupos\"])[\"n\"].transform(lambda s: s/s.sum()*100)\n","\n","    # Ordenação Categórica\n","    tab3[COL_REC] = pd.Categorical(tab3[COL_REC], categories=ordem_rec, ordered=True)\n","    tab3 = tab3.sort_values([COL_REG, \"tipo_3grupos\", COL_REC])\n","\n","except Exception as e:\n","    print(f\"Erro: {e}\")\n","    tab3 = pd.DataFrame()\n","\n","# ==============================================================================\n","# 3. PLOTAGEM (SEPARADA POR REGIÃO)\n","# ==============================================================================\n","def plot_3groups_recurrence():\n","    regions = tab3[COL_REG].unique()\n","    colors = ['#bdc9e1', '#74a9cf', '#0570b0'] # Azul Sequencial\n","\n","    # Ordem fixa para o eixo X (Lógica Institucional)\n","    ordem_eixo_x = [\"Univ. Federais\", \"IFs/CEFETs\", \"Outros tipos\"]\n","\n","    for i, reg in enumerate(regions):\n","        # Preparar dados\n","        sub = tab3[tab3[COL_REG] == reg]\n","        p = sub.pivot_table(index=\"tipo_3grupos\", columns=COL_REC, values=\"pct\", fill_value=0)\n","\n","        # Reordenar Colunas (Recorrência) e Linhas (Tipos)\n","        p = p.reindex(columns=ordem_rec)\n","        p = p.reindex(index=[t for t in ordem_eixo_x if t in p.index])\n","\n","        # Plot\n","        fig, ax = plt.subplots(figsize=(8, 6))\n","        p.plot(kind=\"bar\", stacked=True, ax=ax, color=colors, width=0.6, edgecolor='white')\n","\n","        # === RÓTULOS CONDICIONAIS ===\n","        for idx, c in enumerate(ax.containers):\n","            # idx 2 é a barra do topo (Recorrente/Escura) -> Texto Branco\n","            text_color = 'white' if idx == 2 else '#222'\n","\n","            labels = [f'{v.get_height():.0f}%' if v.get_height() > 3 else '' for v in c]\n","            ax.bar_label(c, labels=labels, label_type='center', fontsize=10, color=text_color, weight='bold')\n","\n","        # Estilo\n","        ax.set_xlabel(\"Agrupamento Institucional\", fontsize=11, weight='bold', labelpad=10)\n","        ax.set_ylabel(\"Percentual dentro do grupo (%)\", fontsize=11, weight='bold')\n","        ax.set_ylim(0, 100)\n","        ax.tick_params(axis='x', rotation=0)\n","\n","        # Legenda\n","        ax.legend(title=\"Nível de Fidelidade\", bbox_to_anchor=(1.02, 1), loc='upper left', frameon=False)\n","\n","        # Títulos APA\n","        fig_num = f\"[U-{i+1}]\"\n","        fig.text(0.02, 0.96, f\"Figura {fig_num}\", fontsize=12, weight='bold')\n","        fig.text(0.02, 0.93, f\"Perfil de Recorrência (3 Grupos): {reg}\", fontsize=12, style='italic')\n","\n","        # Nota\n","        note = (r\"$\\it{Nota.}$ Dados agrupados em três macro-categorias para evidenciar o papel da Rede Federal. \"\n","                \"'Outros tipos' inclui estaduais, privadas e institutos de pesquisa.\")\n","        fig.text(0.02, 0.01, note, fontsize=10, ha='left', wrap=True)\n","\n","        # Salvar\n","        safe_reg = str(reg).replace(\" \", \"_\")\n","        plt.tight_layout(rect=[0, 0.05, 1, 0.90])\n","        plt.savefig(f\"recorrencia_3grupos_{safe_reg}.png\", dpi=300, bbox_inches='tight')\n","        plt.show()\n","\n","plot_3groups_recurrence()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"ffHwbnvOAn1d","executionInfo":{"status":"ok","timestamp":1766087369878,"user_tz":300,"elapsed":6713,"user":{"displayName":"Tiago Anjos","userId":"11164892913379647325"}},"outputId":"d989ac49-22da-49d0-cd14-80bb21be4c8d"},"execution_count":40,"outputs":[{"output_type":"stream","name":"stderr","text":["/tmp/ipython-input-2676232697.py:85: FutureWarning: The default value of observed=False is deprecated and will change to observed=True in a future version of pandas. Specify observed=False to silence this warning and retain the current behavior\n","  p = sub.pivot_table(index=\"tipo_3grupos\", columns=COL_REC, values=\"pct\", fill_value=0)\n"]},{"output_type":"display_data",