ciais Aplicadas': 'Sociais',\n","    'Ciências Humanas': 'Humanas',\n","    'Linguística, Letras e Artes': 'Artes/Letras',\n","    'Multidisciplinar': 'Multi'\n","}\n","df['target_label'] = df[col_area].map(mapa_areas).fillna(df[col_area])\n","\n","# ==============================================================================\n","# CONFIGURAÇÃO DE CORES (IDENTIDADE VISUAL)\n","# ==============================================================================\n","# Cores dos Nós de Origem (Instituições)\n","color_map_inst = {\n","    'Univ. Federal': '#4e79a7',   # Azul Médio\n","    'IF/CEFET': '#1f77b4',        # Azul Forte (Tecnológico)\n","    'Estadual': '#59a14f',        # Verde\n","    'Priv. Sem Fins': '#e15759',  # Vermelho Claro (Comunitária)\n","    'Priv. Com Fins': '#b02a2a',  # Vermelho Escuro (Mercado)\n","    'Inst. Pesquisa': '#edc948'   # Amarelo\n","}\n","\n","# Cor Neutra para os Nós de Destino (Áreas)\n","# Usamos cinza para que a cor do fluxo (que vem da instituição) se destaque\n","node_color_target = '#a0a0a0'\n","\n","# ==============================================================================\n","# PREPARAÇÃO DO SANKEY\n","# ==============================================================================\n","# 1. Calcular fluxos (Origem -> Destino : Contagem)\n","flows = df.groupby(['source_label', 'target_label']).size().reset_index(name='value')\n","\n","# 2. Criar lista única de nós\n","# Ordem forçada para estética (Públicas em cima, Privadas em baixo)\n","ordered_sources = ['IF/CEFET', 'Univ. Federal', 'Estadual', 'Inst. Pesquisa', 'Priv. Sem Fins', 'Priv. Com Fins']\n","ordered_targets = sorted(list(flows['target_label'].unique()))\n","all_nodes = ordered_sources + ordered_targets\n","\n","# Mapear label -> índice\n","node_indices = {label: i for i, label in enumerate(all_nodes)}\n","\n","# 3. Listas para o Plotly\n","source_idxs = flows['source_label'].map(node_indices).tolist()\n","target_idxs = flows['target_label'].map(node_indices).tolist()\n","values = flows['value'].tolist()\n","\n","# 4. Cores dos Nós\n","node_colors_list = []\n","for node in all_nodes:\n","    if node in color_map_inst:\n","        node_colors_list.append(color_map_inst[node])\n","    else:\n","        node_colors_list.append(node_color_target)\n","\n","# 5. Cores dos Links (Com Transparência)\n","def hex_to_rgba(hex_code, alpha=0.4):\n","    hex_code = hex_code.lstrip('#')\n","    return f'rgba({int(hex_code[0:2], 16)}, {int(hex_code[2:4], 16)}, {int(hex_code[4:6], 16)}, {alpha})'\n","\n","link_colors = [hex_to_rgba(color_map_inst[row['source_label']], 0.5) for index, row in flows.iterrows()]\n","\n","# ==============================================================================\n","# PLOTAGEM\n","# ==============================================================================\n","fig = go.Figure(data=[go.Sankey(\n","    node=dict(\n","        pad=15, thickness=20,\n","        line=dict(color=\"white\", width=0.5),\n","        label=all_nodes,\n","        color=node_colors_list\n","    ),\n","    link=dict(\n","        source=source_idxs,\n","        target=target_idxs,\n","        value=values,\n","        color=link_colors\n","    )\n",")])\n","\n","fig.update_layout(\n","    title_text=\"<b>Figura 30</b><br><i>Fluxo Detalhado: Categoria Administrativa → Área do Conhecimento</i>\",\n","    title_font_size=14, font_family=\"Arial\", font_size=12,\n","    plot_bgcolor='white', paper_bgcolor='white',\n","    width=1000, height=600,\n","    margin=dict(l=50, r=50, t=80, b=60)\n",")\n","\n","fig.add_annotation(\n","    text=\"<i>Nota.</i> As cores dos fluxos indicam a origem institucional. Observe o fluxo azul forte (IFs) indo para Exatas,<br>\"\n","         \"enquanto o fluxo vermelho escuro (Priv. Com Fins) foca em Humanas e o vermelho claro (Priv. Sem Fins) abrange Saúde.\",\n","    xref=\"paper\", yref=\"paper\", x=0, y=-0.12, showarrow=False, align=\"left\", font=dict(size=11)\n",")\n","\n","fig.show()"],"metadata