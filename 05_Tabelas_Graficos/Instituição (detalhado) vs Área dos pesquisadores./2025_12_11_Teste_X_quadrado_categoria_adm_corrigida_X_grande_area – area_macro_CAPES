s())]\n","df['source_label'] = df[col_inst].map(mapa_inst_en)\n","\n","mapa_areas_en = {\n","    'Ciências Exatas e da Terra': 'Exact Sci.', 'Ciências Biológicas': 'Bio. Sci.',\n","    'Engenharias': 'Engineering', 'Ciências da Saúde': 'Health',\n","    'Ciências Agrárias': 'Agrarian', 'Ciências Sociais Aplicadas': 'Soc. Sci.',\n","    'Ciências Humanas': 'Humanities', 'Linguística, Letras e Artes': 'Arts/Ling.',\n","    'Multidisciplinar': 'Multi'\n","}\n","df['target_label'] = df[col_area].map(mapa_areas_en).fillna(df[col_area])\n","\n","# Cores EN\n","color_map_inst_en = {\n","    'Federal Univ.': '#4e79a7',\n","    'Fed. Institute': '#1f77b4',\n","    'State Univ.': '#59a14f',\n","    'Priv. Non-Profit': '#e15759',\n","    'Priv. For-Profit': '#b02a2a',\n","    'Res. Institute': '#edc948'\n","}\n","node_color_target = '#a0a0a0'\n","\n","# Preparação\n","flows = df.groupby(['source_label', 'target_label']).size().reset_index(name='value')\n","\n","ordered_sources = ['Fed. Institute', 'Federal Univ.', 'State Univ.', 'Res. Institute', 'Priv. Non-Profit', 'Priv. For-Profit']\n","ordered_targets = sorted(list(flows['target_label'].unique()))\n","all_nodes = ordered_sources + ordered_targets\n","node_indices = {label: i for i, label in enumerate(all_nodes)}\n","\n","source_idxs = flows['source_label'].map(node_indices).tolist()\n","target_idxs = flows['target_label'].map(node_indices).tolist()\n","values = flows['value'].tolist()\n","\n","node_colors_list = []\n","for node in all_nodes:\n","    if node in color_map_inst_en:\n","        node_colors_list.append(color_map_inst_en[node])\n","    else:\n","        node_colors_list.append(node_color_target)\n","\n","def hex_to_rgba(hex_code, alpha=0.4):\n","    hex_code = hex_code.lstrip('#')\n","    return f'rgba({int(hex_code[0:2], 16)}, {int(hex_code[2:4], 16)}, {int(hex_code[4:6], 16)}, {alpha})'\n","\n","link_colors = [hex_to_rgba(color_map_inst_en[row['source_label']], 0.5) for index, row in flows.iterrows()]\n","\n","# Plot\n","fig = go.Figure(data=[go.Sankey(\n","    node=dict(\n","        pad=15, thickness=20,\n","        line=dict(color=\"white\", width=0.5),\n","        label=all_nodes,\n","        color=node_colors_list\n","    ),\n","    link=dict(\n","        source=source_idxs, target=target_idxs, value=values, color=link_colors\n","    )\n",")])\n","\n","fig.update_layout(\n","    title_text=\"<b>Figure 30</b><br><i>Detailed Flow: Administrative Category → Knowledge Area</i>\",\n","    title_font_size=14, font_family=\"Arial\", font_size=12,\n","    plot_bgcolor='white', paper_bgcolor='white',\n","    width=1000, height=600,\n","    margin=dict(l=50, r=50, t=80, b=60)\n",")\n","\n","fig.add_annotation(\n","    text=\"<i>Note.</i> Flow colors indicate institutional origin. Observe the strong blue flow (Fed. Institutes) to Exact Sci.,<br>\"\n","         \"while the dark red flow (For-Profit) targets Humanities and light red (Non-Profit) targets Health.\",\n","    xref=\"paper\", yref=\"paper\", x=0, y=-0.12, showarrow=False, align=\"left\", font=dict(size=11)\n",")\n","\n","fig.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":637},"id":"jPTUe1zd4XFP","executionInfo":{"status":"ok","timestamp":1765565103163,"user_tz":300,"elapsed":39,"user":{"displayName":"Tiago Anjos","userId":"11164892913379647325"}},"outputId":"ce105dcc-e6aa-419c-d365-915de0f65d79"},"execution_count":14,"outputs":[{"output_type":"display_data","data":{"text/html":["<html>\n","<head><meta charset=\"utf-8\" /></head>\n","<body>\n","    <div>            <script src=\"https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.5/MathJax.js?config=TeX-AMS-MML_SVG\"></script><script type=\"text/javascript\">if (window.MathJax && window.MathJax.Hub && window.MathJax.Hub.Config) {window.MathJax.Hub.Config({SVG: {font: \"STIX-Web\"}});}</script>                <script type=\"text/javascript\">window.PlotlyConfig = {MathJaxConfig: 'local'};</script>\n","        <script charset=\"utf-8\" src=\"h